---
layout: nil
---

<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

 <title>{{ site.title }}</title>
 <link href="{{ site.url }}/atom.xml" rel="self"/>
 <link href="{{ site.url }}/"/>
 <updated>{{ site.time | date_to_xmlschema }}</updated>
 <id>{{ site.url }}</id>
 <author>
   <name>{{ site.author.name }}</name>
   <email>{{ site.author.email }}</email>
 </author>

 {% for post in site.posts %}
 <entry>
   <title>{{ post.title }}</title>
   <link href="{{ site.url }}{{ post.url }}"/>
   <updated>{{ post.date | date_to_xmlschema }}</updated>
   <id>{{ site.url }}{{ post.id }}</id>
   {% if post.description %}
   <summary>{{ post.description | xml_escape }}</summary>
   {% elsif post.excerpt %}
   <summary>{{ post.excerpt | strip_html | strip_newlines | truncate: 200 | xml_escape }}</summary>
   {% endif %}
   {% if post.categories %}{% for category in post.categories %}<category term="{{ category | xml_escape }}" />
   {% endfor %}{% endif %}
   {% if post.tags %}{% for tag in post.tags %}<category term="{{ tag | xml_escape }}" label="tag" />
   {% endfor %}{% endif %}
   <author><name>{{ site.author.name }}</name></author>
   <content type="html">{{ post.content | xml_escape }}</content>
 </entry>
 {% endfor %}

</feed>
